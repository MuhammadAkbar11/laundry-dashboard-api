{
  "name": "node-ts-rest-auth",
  "version": "0.0.1",
  "description": "node typescript rest api auth with prisma",
  "main": "index.js",
  "author": "MuhammadAkbar11",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "sharp"
    ]
  },
  "scripts": {
    "start": "node ./build/server.js",
    "start:local": "nodemon ./build/server.js",
    "seed:prod": "node ./build/database/seed/seed.js",
    "db:setup:prod": "node ./build/database/setup.js",
    "db:pull:prod": "npx prisma db pull",
    "db:push:prod": "npx prisma db push",
    "db:sync:prod": "yarn db:push:prod && yarn db:pull:prod",
    "db:migrate:prod": "npx prisma migrate",
    "db:generate:prod": "npx prisma generate",
    "db:studio:prod": "npx prisma studio",
    "dev": "ts-node-dev --respawn --exit-child --transpile-only ./src/server.ts",
    "build": "tsc",
    "seed": "dotenv -e .env.development ts-node ./src/database/seed/seed.ts",
    "db:setup": "dotenv -e .env.development ts-node ./src/database/setup.ts",
    "db:migrate": "dotenv -e .env.development -- npx prisma migrate",
    "db:pull": "dotenv -e .env.development -- npx prisma db pull",
    "db:push": "dotenv -e .env.development -- npx prisma db push",
    "db:sync": "yarn db:push && yarn db:pull",
    "db:generate": "dotenv -e .env.development -- npx prisma generate",
    "db:studio": "dotenv -e .env.development -- npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^4.16.0",
    "bcrypt": "^5.1.0",
    "chalk": "^4.1.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dayjs": "^1.11.7",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-useragent": "^1.0.15",
    "googleapis": "^114.0.0",
    "inquirer": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^4.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "pino": "^8.21.0",
    "pino-http": "^8.6.0",
    "pino-pretty": "^10.3.0",
    "request-ip": "^3.3.0",
    "sharp": "^0.33.0",
    "zod": "^3.23.0",
    "zod-validation-error": "^1.5.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.0",
    "@types/bcrypt": "^5.0.0",
    "@types/body-parser": "^1.19.2",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.21",
    "@types/express-useragent": "^1.0.2",
    "@types/inquirer": "^8.1.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/lodash": "^4.14.192",
    "@types/multer": "^1.4.7",
    "@types/nanoid": "^3.0.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.7",
    "@types/nodemailer": "^6.4.7",
    "@types/request-ip": "^0.0.41",
    "@types/supertest": "^2.0.12",
    "jest": "^29.7.0",
    "prisma": "^4.16.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}