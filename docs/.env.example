NODE_ENV=production
PORT=3001
UPLOAD_PATH=public/uploads

DATABASE_URL='' # db url

# CORS — pipe-delimited list of allowed origins.
# Examples:
#   http://localhost:3379|https://localhost:3379   (development, HTTP + HTTPS)
#   https://laundry.example.com                    (production, single origin)
ALLOWED_ORIGINS=http://localhost:3379

PRIVATE_KEY='' # comment this line if you wanna use the example private key
PUBLIC_KEY='' # comment this line if you wanna use the example public key


# Gmail OAuth2 (primary email provider).
GMAIL=''
OAUTH_CLIENTID=''
OAUTH_CLIENT_SECRET=''
OAUTH_REFRESH_TOKEN=''
OAUTH_PLAYGROUND='https://developers.google.com/oauthplayground'

# ZohoMail SMTP (legacy, used by the developer notification flow).
ZOHOMAIL=''
ZOHOMAIL_PW=''

# Comma-separated list of developer email addresses. Used by the
# OAuth-refresh-token-expiry notification path.
DEVS_EMAIL=''
