generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  user_id    String    @id @db.VarChar(30)
  email      String    @unique @db.VarChar(128)
  name       String
  avatar     String    @db.VarChar(225)
  password   String    @db.VarChar(225)
  role       Role      @default(ADMIN)
  status     Status    @default(PENDING)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  sessions   Session[]

  @@map("tb_users")
}

model Session {
  id          String   @id @default(uuid())
  user_id     String   @db.VarChar(30)
  user_agent  String   @db.LongText
  ip_address  String   @db.VarChar(128)
  device_type String   @db.VarChar(35)
  valid       Boolean
  expired     DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  user        User     @relation(fields: [user_id], references: [user_id])

  @@index([user_id])
  @@map("tb_sessions")
}

/// @@Gen.model(hide: true)
model AutoIncrement {
  id      Int     @id @default(autoincrement())
  tb_name String  @db.VarChar(255)
  field   String? @unique @db.VarChar(20)
  prefix  String? @db.VarChar(25)
  value   BigInt? @default(1)

  @@map("tb_autoincrement")
}

enum Role {
  ADMIN
  OPERATOR
  OFFICER
}

enum Status {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}
