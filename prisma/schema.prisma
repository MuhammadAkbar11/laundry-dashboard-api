generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  user_id  String    @id @db.VarChar(30)
  email    String    @unique @db.VarChar(128)
  name     String
  avatar   String    @db.VarChar(225)
  password String    @db.VarChar(225)
  role     Role      @default(ADMIN)
  status   Status    @default(PENDING)
  sessions Session[]

  @@map("tb_users")
}

model Session {
  id         String   @id @default(uuid())
  user_id    String   @unique @db.VarChar(30)
  user_agent String   @db.LongText
  valid      Boolean
  expired    DateTime
  user       User     @relation(fields: [user_id], references: [user_id])

  @@map("tb_sessions")
}

/// @@Gen.model(hide: true)
model AutoIncrement {
  id      Int     @id @default(autoincrement())
  tb_name String  @db.VarChar(255)
  field   String? @unique @db.VarChar(20)
  prefix  String? @db.VarChar(25)
  value   BigInt? @default(1)

  @@map("tb_autoincrement")
}

enum Role {
  ADMIN
  OPERATOR
  OFFICER
}

enum Status {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}
