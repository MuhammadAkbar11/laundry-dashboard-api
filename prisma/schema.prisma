generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex", "filteredRelationCount", "extendedWhereUnique"]
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  userId    String     @id @map("user_id") @db.VarChar(11)
  email     String     @unique @db.VarChar(128)
  name      String
  avatar    String     @db.VarChar(225)
  password  String     @db.VarChar(225)
  role      Role       @default(ADMIN)
  status    Status     @default(PENDING)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  sessions  Session[]
  payments  Payment[]
  expenses  Expenses[]
  userNotifications UserNotification[]

  @@map("tb_users")
}

model Member {
  memberId   String          @id @map("member_id") @db.VarChar(11)
  email      String          @unique @db.VarChar(128)
  username   String
  avatar     String          @db.VarChar(225)
  password   String          @db.VarChar(225)
  status     Status          @default(PENDING)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  customerId String?         @unique @map("customer_id") @db.VarChar(11)
  customer   Customer?       @relation(fields: [customerId], references: [customerId])
  sessions   MemberSession[]
  memberNotifications MemberNotification[]

  @@index([customerId], map: "cs_id_idx")
  @@map("tb_members")
}

model Session {
  sessionId  String   @id @default(uuid()) @map("id") @db.VarChar(66)
  userId     String   @map("user_id") @db.VarChar(11)
  userAgent  String   @map("user_agent") @db.LongText
  ipAddress  String   @map("ip_address") @db.VarChar(128)
  deviceType String   @map("device_type") @db.VarChar(40)
  valid      Boolean
  expired    DateTime
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [userId])

  @@index([userId], map: "user_id_idx")
  @@map("tb_sessions")
}

model MemberSession {
  memberSessionId String   @id @default(uuid()) @map("id") @db.VarChar(66)
  memberId        String   @map("member_id") @db.VarChar(11)
  userAgent       String   @map("user_agent") @db.LongText
  ipAddress       String   @map("ip_address") @db.VarChar(128)
  deviceType      String   @map("device_type") @db.VarChar(40)
  valid           Boolean
  expired         DateTime
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  member          Member   @relation(fields: [memberId], references: [memberId])

  @@index([memberId], map: "member_id_idx")
  @@map("tb_member_sessions")
}

model Service {
  serviceId   String      @id @map("service_id") @db.VarChar(11)
  name        String      @db.VarChar(128)
  description String      @db.Text
  unit        ServiceUnit
  price       BigInt
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("tb_services")
}

model HistoryService {
  historyServiceId String        @id @map("history_service_id") @db.VarChar(11)
  serviceId        String        @map("service_id") @db.VarChar(11)
  name             String        @db.VarChar(128)
  description      String        @db.Text
  unit             ServiceUnit
  price            BigInt
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  LaundryItem      LaundryItem[]

  @@map("tb_history_services")
}

model LaundryQueue {
  laundryQueueId     String                    @id @map("laundry_queue_id") @db.VarChar(15)
  queuePaymentStatus LaundryQueuePaymentStatus @default(PENDING) @map("payment_status")
  status             LaundryQueueStatus        @default(ONHOLD)
  finishedAt         DateTime?                 @map("finished_at")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  customerId         String                    @map("customer_id") @db.VarChar(11)
  deliveryAt         DateTime?                 @map("delivery_at")
  deliveryType       DeliveryType              @map("delivery_type")
  note               String?                   @db.Text
  deliveryAddress    String?                   @map("delivery_address")
  pickupAt           DateTime?                 @map("pickup_at")
  customer           Customer?                 @relation(fields: [customerId], references: [customerId])
  laundries          LaundryItem[]
  payment            Payment?
  laundryRoom        LaundryRoom?

  @@index([customerId], map: "customer_id_idx")
  @@map("tb_laundry_queues")
}

model LaundryItem {
  laundryId        String          @id @map("laundry_id") @db.VarChar(11)
  quantity         Int
  totalPrice       BigInt          @map("total_price")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  laundryQueueId   String          @map("laundry_queue_id") @db.VarChar(15)
  note             String?         @db.Text
  historyServiceId String          @map("history_service_id") @db.VarChar(11)
  laundryQueue     LaundryQueue    @relation(fields: [laundryQueueId], references: [laundryQueueId])
  historyService   HistoryService? @relation(fields: [historyServiceId], references: [historyServiceId])

  @@index([laundryQueueId], map: "ldry_queue_id_idx")
  @@index([historyServiceId], map: "history_service_id_idx")
  @@map("tb_laundries")
}

model CustomerLevel {
  customerLevelId String     @id @map("cs_level_id") @db.VarChar(11)
  name            String     @db.VarChar(255)
  point           BigInt
  discount        Int
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  customers       Customer[]

  @@map("tb_customer_levels")
}

model Customer {
  customerId      String         @id @map("customer_id") @db.VarChar(11)
  name            String         @db.VarChar(33)
  address         String?        @db.Text
  phone           String?        @db.VarChar(21)
  customerLevelId String         @map("cs_level_id") @db.VarChar(11)
  point           Int            @default(0)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  customerLevel   CustomerLevel  @relation(fields: [customerLevelId], references: [customerLevelId])
  laundryQueues   LaundryQueue[]
  Member          Member?

  @@index([customerLevelId], map: "cs_level_id_idx")
  @@map("tb_customers")
}

model CashFlow {
  cashflowId      String       @id @map("cashflow_id") @db.VarChar(11)
  description     String       @db.Text
  cashflowType    CashFlowType @map("cashflow_type")
  total           BigInt
  balance         BigInt
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  cashflowInvoice String       @map("cashflow_invoice") @db.VarChar(15)

  @@map("tb_cashflow")
}

model Payment {
  paymentId      String        @id @map("payment_id") @db.VarChar(11)
  invoice        String        @unique @db.VarChar(15)
  price          BigInt
  discount       Int
  paid           BigInt
  cashback       BigInt
  paymentMethod  PaymentMethod @map("payment_method")
  createdAt      String        @map("created_at")
  updatedAt      String        @map("updated_at")
  userId         String?       @map("user_id") @db.VarChar(11)
  laundryQueueId String        @unique @map("laundry_queue_id") @db.VarChar(15)
  totalPrice     BigInt        @map("total_price")
  totalLaundry   Int           @map("total_laundry")
  proof          String?       @db.VarChar(128)
  user           User?         @relation(fields: [userId], references: [userId])
  laundryQueue   LaundryQueue  @relation(fields: [laundryQueueId], references: [laundryQueueId])

  @@index([laundryQueueId], map: "ldry_queue_id_idx")
  @@index([userId], map: "user_id_idx")
  @@map("tb_payments")
}

model Expenses {
  expensesId      String   @id @map("expenses_id") @db.VarChar(11)
  description     String   @db.Text
  total           BigInt
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  userId          String   @map("user_id") @db.VarChar(11)
  expensesInvoice String   @map("expenses_invoice") @db.VarChar(13)
  user            User     @relation(fields: [userId], references: [userId])

  @@index([userId], map: "user_id_idx")
  @@map("tb_expenses")
}

model LaundryRoom {
  laundryRoomId  String            @id @map("laundry_room_id") @db.VarChar(15)
  total          Int?
  status         LaundryRoomStatus
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  laundryQueueId String            @unique @map("laundry_queue_id") @db.VarChar(15)
  laundryQueue   LaundryQueue      @relation(fields: [laundryQueueId], references: [laundryQueueId])

  @@index([laundryQueueId], map: "ldry_queue_id_idx")
  @@map("tb_laundry_rooms")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.VarChar(36)
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  userId    String?   @map("user_id") @db.VarChar(11)
  memberId  String?   @map("member_id") @db.VarChar(11)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId], map: "prt_user_id_idx")
  @@index([memberId], map: "prt_member_id_idx")
  @@map("tb_password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.VarChar(36)
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  memberId  String    @map("member_id") @db.VarChar(11)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([memberId], map: "evt_member_id_idx")
  @@map("tb_email_verification_tokens")
}

model Setting {
  settingId   BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name        String   @unique @db.VarChar(255)
  description String   @db.Text
  value       String   @db.LongText
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tb_settings")
}

model NotificationType {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        String   @unique @db.VarChar(64)
  name        String   @db.VarChar(128)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  templates   NotificationTemplate[]
  notifications Notification[]

  @@map("tb_notification_types")
}

model NotificationTemplate {
  id               String   @id @default(uuid()) @db.VarChar(36)
  notificationTypeId String @map("notification_type_id") @db.VarChar(36)
  channel          String   @default("IN_APP") @db.VarChar(20)
  titleTemplate    String   @map("title_template") @db.VarChar(255)
  messageTemplate  String   @map("message_template") @db.Text
  supportedVariables String? @map("supported_variables") @db.Text
  defaultTitleTemplate String? @map("default_title_template") @db.VarChar(255)
  defaultMessageTemplate String? @map("default_message_template") @db.Text
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  notificationType NotificationType @relation(fields: [notificationTypeId], references: [id])

  @@index([notificationTypeId], map: "ntpl_ntype_id_idx")
  @@map("tb_notification_templates")
}

model Notification {
  id               String   @id @default(uuid()) @db.VarChar(36)
  notificationTypeId String @map("notification_type_id") @db.VarChar(36)
  title            String   @db.VarChar(255)
  message          String   @db.Text
  metadata         String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  notificationType NotificationType @relation(fields: [notificationTypeId], references: [id])
  memberNotifications MemberNotification[]
  userNotifications UserNotification[]

  @@index([notificationTypeId], map: "notif_ntype_id_idx")
  @@map("tb_notifications")
}

model MemberNotification {
  id             String    @id @default(uuid()) @db.VarChar(36)
  notificationId String    @map("notification_id") @db.VarChar(36)
  memberId       String    @map("member_id") @db.VarChar(11)
  isRead         Boolean   @default(false) @map("is_read")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  notification   Notification @relation(fields: [notificationId], references: [id])
  member         Member       @relation(fields: [memberId], references: [memberId])

  @@index([memberId], map: "mnotif_member_id_idx")
  @@index([notificationId], map: "mnotif_notif_id_idx")
  @@map("tb_member_notifications")
}

model UserNotification {
  id             String    @id @default(uuid()) @db.VarChar(36)
  notificationId String    @map("notification_id") @db.VarChar(36)
  userId         String?   @map("user_id") @db.VarChar(11)
  isGlobal       Boolean   @default(false) @map("is_global")
  isRead         Boolean   @default(false) @map("is_read")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  notification   Notification @relation(fields: [notificationId], references: [id])
  user           User?        @relation(fields: [userId], references: [userId])

  @@index([userId], map: "unotif_user_id_idx")
  @@index([notificationId], map: "unotif_notif_id_idx")
  @@map("tb_user_notifications")
}

/// @@Gen.model(hide: true)
model AutoIncrement {
  id     Int     @id @default(autoincrement())
  tbName String  @map("tb_name") @db.VarChar(255)
  field  String? @unique @db.VarChar(20)
  prefix String? @db.VarChar(25)
  value  BigInt? @default(1)

  @@map("tb_autoincrement")
}

enum ServiceUnit {
  KG   @map("Kg")
  PTNG @map("Ptng")
}

enum Role {
  ADMIN
  CASHIER
  OFFICER
}

enum CashFlowType {
  IN  @map("Masuk")
  OUT @map("Keluar")
}

enum LaundryQueueStatus {
  PENDING  @map("pending")
  CANCELED @map("canceled")
  ONHOLD   @map("onhold")
  WASHED   @map("washed")
  FINISHED @map("finished")
}

enum LaundryRoomStatus {
  READY    @map("ready")
  WASHED   @map("washed")
  FINISHED @map("finished")
}

enum PaymentMethod {
  CASH          @map("tunai")
  BANK_TRANSFER @map("bank_transfer")
  GOPAY         @map("gopay")
  DANA          @map("dana")
}

enum LaundryQueuePaymentStatus {
  PENDING   @map("pending")
  PROCESSED @map("processed")
  REJECTED  @map("rejected")
  FINISHED  @map("finished")
}

enum Status {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DeliveryType {
  DELIVERED @map("delivered")
  PICKUP    @map("pickup")
}
